---
import type { Book } from '../../data/books';

interface Props {
  book: Book;
}

const { book } = Astro.props;
---

<section class="py-[120px] bg-black">
  <div class="max-w-[1296px] mx-auto px-16">
    <div class="flex items-center gap-4 mb-16">
      <div class="w-10 h-0.5 bg-secondary"></div>
      <h2 class="font-label-caps text-label-caps text-secondary tracking-widest">WHAT READERS ARE SAYING</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-zinc-800">
      {book.testimonials.map(({ quote, source, outlet }) => (
        <div class="bg-black p-12 flex flex-col gap-8 hover:bg-zinc-900 transition-colors duration-300">
          <div class="text-5xl text-secondary font-serif leading-none select-none">&ldquo;</div>
          <p class="font-body-lg text-body-lg text-white leading-relaxed flex-1 italic">{quote}</p>
          <div>
            <p class="font-label-caps text-label-caps text-secondary tracking-widest">{source}</p>
            <p class="font-data-mono text-data-mono text-zinc-400 mt-1">{outlet}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
