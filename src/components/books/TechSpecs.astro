---
import type { Book } from '../../data/books';

interface Props {
  book: Book;
}

const { book } = Astro.props;

const specs = [
  { label: 'Series', value: `The Conor Thorn Series — Book ${book.number}` },
  { label: 'Genre', value: book.genre },
  { label: 'Setting', value: book.setting },
  { label: 'Formats', value: 'Hardcover · Paperback · Ebook · Audiobook' },
  { label: 'Box Set', value: 'Books 1–4 available for $9.99' },
];
---

<section class="bg-surface-container py-16 md:py-[120px]">
  <div class="max-w-[1296px] mx-auto px-4 md:px-16">
    <div class="grid grid-cols-12 gap-8">

      <div class="col-span-12 md:col-span-4 mb-12 md:mb-0">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-0.5 bg-secondary"></div>
          <span class="font-label-caps text-label-caps text-secondary tracking-widest">BOOK DETAILS</span>
        </div>
        <h2 class="font-headline-md text-headline-md text-primary font-bold tracking-tight">{book.title}</h2>
        <p class="mt-4 font-body-md text-body-md text-on-surface-variant leading-relaxed">
          Available wherever books are sold, in every format.
        </p>
      </div>

      <div class="col-span-12 md:col-span-7 md:col-start-6">
        <table class="w-full text-left">
          <tbody>
            {specs.map(({ label, value }) => (
              <tr class="border-b border-outline-variant">
                <td class="py-6 font-label-caps text-label-caps text-on-surface-variant tracking-widest w-1/3">{label}</td>
                <td class="py-6 font-body-md text-body-md text-primary">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

    </div>
  </div>
</section>
