---
const quotes = [
  { text: 'One of the more underrated spy franchises set during WWII.', source: 'Ryan Steck', outlet: 'The Real Book Spy' },
  { text: 'Gripping WWII espionage thriller rich in history and suspense.', source: 'BookLife Reviews', outlet: 'Publishers Weekly' },
  { text: 'A propulsive, masterfully crafted WWII thriller.', source: 'Chris Wallace', outlet: 'CNN' },
];
---

<section class="py-[120px] bg-black">
  <div class="max-w-[1296px] mx-auto px-16">

    <div class="flex items-center gap-4 mb-16">
      <div class="w-10 h-0.5 bg-secondary"></div>
      <span class="font-label-caps text-label-caps text-secondary tracking-widest">READER PRAISE</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-outline-variant">
      {quotes.map(({ text, source, outlet }) => (
        <div class="bg-black p-12 flex flex-col gap-8 hover:bg-surface-container transition-colors duration-300">
          <div class="text-5xl text-secondary font-serif leading-none select-none">&ldquo;</div>
          <p class="font-body-lg text-body-lg text-primary leading-relaxed flex-1">
            {text}
          </p>
          <div>
            <p class="font-label-caps text-label-caps text-secondary tracking-widest">{source}</p>
            <p class="font-data-mono text-data-mono text-on-surface-variant mt-1">{outlet}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <p class="font-body-lg text-body-lg text-on-surface-variant italic">
        "Perfect fit for fans of Alan Furst" · Endorsed by Steve Berry, Jack Carr &amp; Chris Wallace
      </p>
    </div>

  </div>
</section>
