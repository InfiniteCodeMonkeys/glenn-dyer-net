---
const quotes = [
    {
        text: "One of the more underrated spy franchises set during WWII.",
        source: "Ryan Steck",
        outlet: "The Real Book Spy",
    },
    {
        text: "Gripping WWII espionage thriller rich in history and suspense.",
        source: "BookLife Reviews",
        outlet: "Publishers Weekly",
    },
    {
        text: "A propulsive, masterfully crafted WWII thriller.",
        source: "Chris Wallace",
        outlet: "CNN",
    },
];
---

<!-- Replace src below with your chosen background image -->
<header class="relative w-full h-screen flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img
            class="w-full h-full object-cover"
            src="./talking_at_dollys.jpg"
            alt=""
        />
        <div class="absolute inset-0 bg-black/65"></div>
    </div>

    <div
        class="relative z-10 w-full max-w-[1296px] mx-auto px-4 md:px-8 lg:px-16"
    >
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- Left: rotating critical acclaim -->
            <div>
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-0.5 bg-secondary"></div>
                    <h2
                        class="font-label-caps text-base font-bold text-secondary tracking-wider uppercase"
                    >
                        Critical Acclaim
                    </h2>
                </div>

                <div class="relative" style="min-height: 200px;">
                    {
                        quotes.map((q, i) => (
                            <div
                                class="acclaim-quote absolute inset-0"
                                data-index={i}
                                style={`opacity: ${i === 0 ? 1 : 0}; transition: opacity 800ms ease-in-out;`}
                            >
                                <div class="text-7xl text-secondary font-serif leading-none select-none mb-4">
                                    &ldquo;
                                </div>
                                <p class="text-4xl font-medium text-white leading-snug mb-6 max-w-lg">
                                    {q.text}
                                </p>
                                <div>
                                    <p class="font-label-caps text-base font-bold text-secondary tracking-widest uppercase">
                                        {q.source}
                                    </p>
                                    <p class="font-data-mono text-data-mono text-zinc-400 mt-1">
                                        {q.outlet}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- Right: 3D boxset -->
            <div class="flex justify-center lg:justify-end items-center">
                <!-- <img
                    src="./bookset_3d.png"
                    alt="The Conor Thorn Series — complete boxset"
                    class="max-w-full max-h-[55vh] object-contain drop-shadow-2xl"
                /> -->
            </div>
        </div>
    </div>
</header>

<script>
    const quotes = document.querySelectorAll<HTMLElement>(".acclaim-quote");
    let current = 0;
    const FADE = 800;
    const DISPLAY = 5000;

    function cycle() {
        quotes[current].style.opacity = "0";
        setTimeout(() => {
            current = (current + 1) % quotes.length;
            quotes[current].style.opacity = "1";
            setTimeout(cycle, DISPLAY + FADE);
        }, FADE);
    }

    setTimeout(cycle, DISPLAY + FADE);
</script>
