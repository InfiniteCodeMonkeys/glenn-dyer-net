---
interface Props {
  activePage?: 'home' | 'books' | 'about' | 'newsletter' | 'contact';
}

const { activePage } = Astro.props;

const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/books', label: 'Books', key: 'books' },
  { href: '/about', label: 'About', key: 'about' },
  { href: '/newsletter', label: 'Newsletter', key: 'newsletter' },
  { href: '/contact', label: 'Contact', key: 'contact' },
];
---

<nav class="bg-background w-full border-b-2 border-secondary fixed top-0 z-50">
  <div class="flex justify-between items-center px-4 md:px-8 lg:px-16 py-5 md:py-7">
    <a href="/" class="text-xl font-bold tracking-widest uppercase text-on-surface font-headline-md no-underline hover:text-secondary transition-colors">
      GLENN DYER
    </a>

    <div class="hidden md:flex items-center space-x-10">
      {links.map(({ href, label, key }) => (
        <a
          href={href}
          class={[
            'font-label-caps text-label-caps tracking-widest transition-colors duration-200 uppercase',
            activePage === key
              ? 'text-secondary'
              : 'text-on-surface-variant hover:text-on-surface',
          ].join(' ')}
        >
          {label}
        </a>
      ))}
    </div>

    <a
      href="/books/trust-no-one"
      class="hidden md:inline-block bg-secondary text-white px-7 py-3 font-label-caps text-label-caps tracking-widest hover:bg-on-surface hover:text-background transition-colors duration-200"
    >
      ORDER NOW
    </a>

    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-primary hover:text-secondary transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="material-symbols-outlined" id="mobile-menu-icon">menu</span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-outline-variant bg-background px-4 pb-6"
  >
    <div class="flex flex-col gap-1 pt-4">
      {links.map(({ href, label, key }) => (
        <a
          href={href}
          class={[
            'font-label-caps text-label-caps tracking-widest uppercase py-3 border-b border-outline-variant transition-colors duration-200',
            activePage === key
              ? 'text-secondary'
              : 'text-on-surface-variant hover:text-on-surface',
          ].join(' ')}
        >
          {label}
        </a>
      ))}
      <a
        href="/books/trust-no-one"
        class="mt-4 bg-secondary text-white px-7 py-4 font-label-caps text-label-caps tracking-widest text-center hover:bg-on-surface hover:text-background transition-colors duration-200"
      >
        ORDER NOW
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLDivElement;
  const icon = document.getElementById('mobile-menu-icon') as HTMLSpanElement;

  btn?.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    icon.textContent = isOpen ? 'menu' : 'close';
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      icon.textContent = 'menu';
      btn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
