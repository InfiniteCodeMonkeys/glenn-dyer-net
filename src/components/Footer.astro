---
const navLinks = [
    { href: "/books/trust-no-one", label: "Books" },
    { href: "/about", label: "About" },
    { href: "/newsletter", label: "Newsletter" },
    { href: "/contact", label: "Contact" },
];

const socialLinks = [
    { href: "https://www.facebook.com/GlennDyerAuthor", label: "Facebook" },
    { href: "https://twitter.com/GlennDyerAuthor", label: "Twitter / X" },
    { href: "https://www.instagram.com/glennduffydyer", label: "Instagram" },
    { href: "https://www.linkedin.com/in/glenndyer", label: "LinkedIn" },
];
---

<footer class="bg-black border-t-2 border-secondary">
    <div class="max-w-[1296px] mx-auto px-4 md:px-16 py-12 md:py-20">
        <div class="grid grid-cols-12 gap-8 mb-16">
            <div class="col-span-12 md:col-span-5">
                <p
                    class="font-label-caps text-label-caps text-secondary tracking-widest mb-3"
                >
                    GLENN DYER
                </p>
                <p
                    class="font-headline-md text-2xl text-white font-bold tracking-tight mb-6"
                >
                    Author of the Conor Thorn Series
                </p>
                <p
                    class="font-body-md text-body-md text-zinc-500 leading-relaxed max-w-sm"
                >
                    WWII espionage thrillers praised for their meticulous
                    research and pulse-pounding suspense.
                </p>
            </div>

            <div class="col-span-6 md:col-span-3 md:col-start-8">
                <h4
                    class="font-label-caps text-label-caps text-zinc-600 mb-6 tracking-widest"
                >
                    NAVIGATE
                </h4>
                <ul class="space-y-3">
                    {
                        navLinks.map(({ href, label }) => (
                            <li>
                                <a
                                    href={href}
                                    class="font-body-md text-zinc-500 hover:text-white transition-colors"
                                >
                                    {label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <div class="col-span-6 md:col-span-2">
                <h4
                    class="font-label-caps text-label-caps text-zinc-600 mb-6 tracking-widest"
                >
                    FOLLOW
                </h4>
                <ul class="space-y-3">
                    {
                        socialLinks.map(({ href, label }) => (
                            <li>
                                <a
                                    href={href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="font-body-md text-zinc-500 hover:text-secondary transition-colors"
                                >
                                    {label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>

        <div
            class="border-t border-zinc-900 pt-8 flex flex-col md:flex-row justify-between items-center gap-4"
        >
            <p
                class="text-zinc-700 font-label-caps text-[10px] uppercase tracking-[0.2em]"
            >
                © 2026 Glenn Dyer. All Rights Reserved.
            </p>
            <a
                href="/contact"
                class="text-zinc-700 hover:text-secondary font-label-caps text-[10px] uppercase tracking-[0.2em] transition-colors"
                >Contact</a
            >
        </div>
    </div>
</footer>
