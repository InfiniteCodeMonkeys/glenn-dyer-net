---
const books = [
    {
        year: "2019",
        label: "BOOK ONE",
        labelColor: "text-secondary",
        dotColor: "bg-secondary",
        title: "The Torch Betrayal",
        description:
            "The debut Conor Thorn novel. Set against Operation Torch—the Allied invasion of North Africa—Thorn races to stop a German agent from unraveling the entire operation before D-Day.",
        showLine: true,
    },
    {
        year: "2020",
        label: "BOOK TWO",
        labelColor: "text-zinc-500",
        dotColor: "bg-zinc-600",
        title: "The Ultra Betrayal",
        description:
            "When the Allies' most closely guarded secret—the Ultra decryption program—is threatened by a double agent, Thorn must penetrate Nazi-controlled Europe to prevent catastrophe.",
        showLine: true,
    },
    {
        year: "2021",
        label: "BOOK THREE",
        labelColor: "text-zinc-500",
        dotColor: "bg-zinc-600",
        title: "The Unquiet Genius",
        description:
            "A brilliant scientist with knowledge that could change the outcome of the war has vanished. Thorn's mission: find him before the Germans do.",
        showLine: true,
    },
    {
        year: "2022",
        label: "BOOK FOUR",
        labelColor: "text-zinc-500",
        dotColor: "bg-zinc-600",
        title: "Trust No One",
        description:
            "A decoded German transmission points to a traitor inside Allied command. Dispatched into occupied France, Thorn must uncover the truth before a catastrophic operation is destroyed from within.",
        showLine: true,
    },
    {
        year: "2026",
        label: "BOOK FIVE",
        labelColor: "text-secondary",
        dotColor: "bg-secondary",
        title: "Debts Owed",
        description:
            "The latest installment in the Conor Thorn series. Available now in ebook, paperback, hardcover, and audiobook.",
        showLine: false,
    },
];
---

<section class="px-4 md:px-16 py-16 md:py-[120px] bg-surface-container">
    <div class="max-w-[1296px] mx-auto">
        <div class="flex items-center gap-4 mb-20">
            <div class="w-10 h-0.5 bg-secondary"></div>
            <h2
                class="font-headline-lg text-headline-lg text-primary font-bold tracking-tight"
            >
                The Conor Thorn Series
            </h2>
        </div>

        <div class="max-w-3xl">
            {
                books.map(
                    ({
                        year,
                        label,
                        labelColor,
                        dotColor,
                        title,
                        description,
                        showLine,
                    }) => (
                        <div class="flex items-start gap-10 mb-16 relative">
                            <div class="hidden md:block w-16 shrink-0 pt-1 text-right">
                                <span class="font-data-mono text-data-mono text-zinc-600">
                                    {year}
                                </span>
                            </div>
                            <div class="relative pt-1 pl-8 border-l border-outline-variant flex-1">
                                <div
                                    class={`w-3 h-3 ${dotColor} rounded-full absolute -left-[7px] top-2`}
                                />
                                <p
                                    class={`font-label-caps text-label-caps tracking-widest mb-2 ${labelColor}`}
                                >
                                    {label}
                                </p>
                                <h5 class="font-headline-md text-headline-md text-primary font-bold mb-3 tracking-tight">
                                    {title}
                                </h5>
                                <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
                                    {description}
                                </p>
                            </div>
                        </div>
                    ),
                )
            }
        </div>
    </div>
</section>
