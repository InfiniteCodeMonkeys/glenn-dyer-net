---

<section class="mb-16 md:mb-[120px] border-b border-outline-variant pb-16">
  <div class="grid grid-cols-12 gap-8">
    <div class="col-span-12 md:col-span-8">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-10 h-0.5 bg-secondary"></div>
        <p class="font-label-caps text-label-caps text-secondary tracking-widest">GLENN DYER</p>
      </div>
      <h1 class="font-headline-xl text-headline-xl text-primary font-bold tracking-tight mb-8">Newsletter</h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl leading-relaxed">
        Research notes, book news, exclusive content, and behind-the-scenes updates from the world of the Conor Thorn series.
      </p>
    </div>

    <div class="col-span-12 md:col-span-4 flex flex-col justify-end items-start md:items-end">
      <label class="font-label-caps text-label-caps text-on-surface-variant tracking-widest mb-3 block">SUBSCRIBE</label>
      <div class="flex border-b border-outline-variant w-full focus-within:border-secondary transition-colors">
        <input
          type="email"
          placeholder="Your email address"
          class="bg-transparent outline-none font-body-md text-body-md text-primary placeholder:text-on-surface-variant w-full py-3 focus:outline-none"
        />
        <button class="p-2 text-on-surface-variant hover:text-secondary transition-colors">
          <span class="material-symbols-outlined">arrow_forward</span>
        </button>
      </div>
    </div>
  </div>
</section>
