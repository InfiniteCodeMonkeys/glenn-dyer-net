---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import BookHero from '../../components/books/BookHero.astro';
import TechSpecs from '../../components/books/TechSpecs.astro';
import BookTestimonials from '../../components/books/BookTestimonials.astro';
import BookInterstitial from '../../components/books/BookInterstitial.astro';
import BookRequisition from '../../components/books/BookRequisition.astro';
import { getBook } from '../../data/books';

const book = await getBook('trust-no-one');
if (!book) return Astro.redirect('/books');
---

<Layout
  title="Trust No One | Glenn Dyer"
  description="Trust No One—Book Four in Glenn Dyer's Conor Thorn WWII espionage series."
>
  <NavBar activePage="books" />

  <main class="pt-[140px]">
    <BookHero book={book} />
    <TechSpecs book={book} />
    <BookTestimonials book={book} />
    <BookInterstitial book={book} />
    <BookRequisition book={book} />
  </main>

  <Footer />
</Layout>
