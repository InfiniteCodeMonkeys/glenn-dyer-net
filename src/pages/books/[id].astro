---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import BookHero from '../../components/books/BookHero.astro';
import TechSpecs from '../../components/books/TechSpecs.astro';
import BookTestimonials from '../../components/books/BookTestimonials.astro';
import BookInterstitial from '../../components/books/BookInterstitial.astro';
import BookRequisition from '../../components/books/BookRequisition.astro';
import { getBooks } from '../../data/books';

export async function getStaticPaths() {
  const books = await getBooks();
  return books.map((book) => ({
    params: { id: book.id },
    props: { book },
  }));
}

const { book } = Astro.props;
---

<Layout
  title={`${book.title} | Glenn Dyer`}
  description={`${book.title}—Book ${book.number} in Glenn Dyer's Conor Thorn WWII espionage series. ${book.briefDescription}`}
>
  <NavBar activePage="books" />

  <main class="pt-[140px]">
    <BookHero book={book} />
    <TechSpecs book={book} />
    <BookTestimonials book={book} />
    <BookInterstitial book={book} />
    <BookRequisition book={book} />
  </main>

  <Footer />
</Layout>
