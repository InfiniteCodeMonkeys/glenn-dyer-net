# Keystatic — GitHub storage (production)
# Set KEYSTATIC_STORAGE_KIND=github to switch from local to GitHub mode
KEYSTATIC_STORAGE_KIND=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Keystatic GitHub OAuth app
# Create at: https://github.com/settings/developers → OAuth Apps
# Homepage URL: https://glenndyer.net
# Callback URL: https://glenndyer.net/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Generate with: openssl rand -base64 32
KEYSTATIC_SECRET=


# Cloudflare Turnstile — contact form spam protection
# Create a site at: https://dash.cloudflare.com → Turnstile
# Use "Managed" challenge type; add glenndyer.net as the hostname
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend — contact form email delivery
# Get API key at: https://resend.com/api-keys
RESEND_API_KEY=
# The email address that receives contact form submissions
CONTACT_TO_EMAIL=
